# FreePalp — переменные окружения
# Скопируй этот файл в .env и заполни ключи

# ──────────────────────────────────────────────────────
# Groq API (бесплатный tier: ~14 400 req/day)
# Получить: https://console.groq.com/keys
# ──────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
# Дополнительные ключи для увеличения квоты (key rotation):
# GROQ_API_KEY_2=gsk_yyyyyyy
# GROQ_API_KEY_3=gsk_zzzzzzz

# ──────────────────────────────────────────────────────
# Cerebras (бесплатный: ~30 000 req/day, очень быстро)
# Получить: https://cloud.cerebras.ai/
# ──────────────────────────────────────────────────────
# CEREBRAS_API_KEY=csk_xxxxxxxxxxxxxxxxxxxxxxxx
# CEREBRAS_API_KEY_2=csk_yyyyyyyy

# ──────────────────────────────────────────────────────
# Google Gemini (бесплатный: 1 500 req/day, 1M контекст)
# Получить: https://aistudio.google.com/apikey
# ──────────────────────────────────────────────────────
# GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxx
# GEMINI_API_KEY_2=AIzayyyyyyyyyyyyy

# ──────────────────────────────────────────────────────
# OpenRouter (бесплатные модели с суффиксом :free)
# Получить: https://openrouter.ai/keys
# ──────────────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx

# ──────────────────────────────────────────────────────
# SambaNova (бесплатный: Llama-405B, DeepSeek)
# Получить: https://cloud.sambanova.ai/
# ──────────────────────────────────────────────────────
# SAMBANOVA_API_KEY=xxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────
# Mistral La Plateforme (очень щедрый free: 1 млрд токенов/мес!)
# Получить: https://console.mistral.ai/api-keys
# ──────────────────────────────────────────────────────
# MISTRAL_API_KEY=xxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────
# z.ai (Zhipu GLM) — glm-4.5-flash БЕСПЛАТНА
# Получить (формат id.secret): https://z.ai → Dashboard → API Keys
# ──────────────────────────────────────────────────────
# ZAI_API_KEY=xxxxxxxxxxxxxxxx.xxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────
# NVIDIA NIM — 100+ open-моделей, бесплатно без карты
# Получить: https://build.nvidia.com (ключ вида nvapi-...)
# ──────────────────────────────────────────────────────
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────
# Cohere — free trial-tier, Command-модели
# Получить: https://dashboard.cohere.com/api-keys
# ──────────────────────────────────────────────────────
# COHERE_API_KEY=xxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────
# Together AI ($5 кредитов при регистрации)
# Получить: https://api.together.xyz/settings/api-keys
# ──────────────────────────────────────────────────────
# TOGETHER_API_KEY=xxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────
# Anthropic Claude (платный — высшее качество)
# Получить: https://console.anthropic.com/settings/keys
# ──────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────
# Ollama (локальный — без лимитов, без интернета)
# Установить: https://ollama.com/download
# Запустить:  ollama serve
# Модели:     ollama pull qwen2.5-coder:7b
# ──────────────────────────────────────────────────────
# OLLAMA_HOST=http://localhost:11434   # (по умолчанию)

# ──────────────────────────────────────────────────────
# Настройки системы
# ──────────────────────────────────────────────────────
MAX_ITERATIONS=3
LOG_LEVEL=INFO
